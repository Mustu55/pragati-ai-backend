PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/pragati-ai
JWT_SECRET=your_super_secret_jwt_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Must be a model supported by your Gemini API for the installed SDK/API version.
# After changing this, restart the backend.
GEMINI_CHAT_MODEL=gemini-2.0-flash
